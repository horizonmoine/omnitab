# Copy to .env and edit if you want to override defaults.
# Leave commented to use the defaults baked into docker-compose.yml.

# Host port to expose the backend on. Default 8000.
# PORT=8000

# Cache-bust string for the yt-dlp upgrade step. Bump this whenever you
# want to force a fresh `pip install --upgrade yt-dlp` on the next
# `docker compose up --build`. Format is free — only the *value*
# changing matters (not the format).
# YTDLP_CACHE_BUST=2026-04-25-manual-rebuild
