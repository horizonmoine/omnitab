{
  "name": "omnitab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PWA guitar companion — AlphaTab viewer, Songsterr search, tuner, amp sim, AI transcription (basic-pitch), chord-melody generator.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@coderline/alphatab": "1.5.0",
    "@spotify/basic-pitch": "^1.0.1",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "pitchy": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tonal": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
